{
  "info": {
    "name": "FirstFrost",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "FirstFrost grow-tracking backend. PostgreSQL on Supabase, tested through PostgREST. AD350 capstone."
  },
  "variable": [
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const token = pm.collectionVariables.get('accessToken') || pm.environment.get('accessToken');",
          "if (token) {",
          "    pm.request.headers.add({",
          "        key: 'Authorization',",
          "        value: `Bearer ${token}`",
          "    });",
          "}",
          "pm.request.headers.add({",
          "    key: 'apikey',",
          "    value: pm.environment.get('anonKey')",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth: Sign In",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const res = pm.response.json();",
              "pm.collectionVariables.set('accessToken', res.access_token);",
              "pm.environment.set('userId', res.user.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"your-email@example.com\",\n  \"password\": \"your-password\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/v1/token?grant_type=password",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "v1", "token"],
          "query": [
            {
              "key": "grant_type",
              "value": "password"
            }
          ]
        }
      }
    },
    {
      "name": "Profiles: Get Own",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/rest/v1/profiles?id=eq.{{userId}}",
          "host": ["{{baseUrl}}"],
          "path": ["rest", "v1", "profiles"],
          "query": [
            {
              "key": "id",
              "value": "eq.{{userId}}"
            }
          ]
        }
      }
    },
    {
      "name": "Profiles: Update Display Name",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Prefer",
            "value": "return=representation"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"display_name\": \"Rae\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/rest/v1/profiles?id=eq.{{userId}}",
          "host": ["{{baseUrl}}"],
          "path": ["rest", "v1", "profiles"],
          "query": [
            {
              "key": "id",
              "value": "eq.{{userId}}"
            }
          ]
        }
      }
    },
    {
      "name": "Spaces: Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Prefer",
            "value": "return=representation"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"{{userId}}\",\n  \"name\": \"Rooftop Garden\",\n  \"space_type\": \"outdoor\",\n  \"description\": \"Container beds on the roof\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/rest/v1/spaces",
          "host": ["{{baseUrl}}"],
          "path": ["rest", "v1", "spaces"]
        }
      }
    },
    {
      "name": "Spaces: Get All",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/rest/v1/spaces?user_id=eq.{{userId}}",
          "host": ["{{baseUrl}}"],
          "path": ["rest", "v1", "spaces"],
          "query": [
            {
              "key": "user_id",
              "value": "eq.{{userId}}"
            }
          ]
        }
      }
    },
    {
      "name": "Spaces: Update Name",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Prefer",
            "value": "return=representation"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Rooftop Garden 2026\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/rest/v1/spaces?id=eq.{{spaceId}}",
          "host": ["{{baseUrl}}"],
          "path": ["rest", "v1", "spaces"],
          "query": [
            {
              "key": "id",
              "value": "eq.{{spaceId}}"
            }
          ]
        }
      }
    },
    {
      "name": "Plants: Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Prefer",
            "value": "return=representation"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"space_id\": \"{{spaceId}}\",\n  \"user_id\": \"{{userId}}\",\n  \"common_name\": \"Pepper\",\n  \"variety\": \"Jalapeño\",\n  \"planted_date\": \"2026-06-14\",\n  \"current_stage\": \"seedling\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/rest/v1/plants",
          "host": ["{{baseUrl}}"],
          "path": ["rest", "v1", "plants"]
        }
      }
    },
    {
      "name": "Plants: Get by Space",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/rest/v1/plants?space_id=eq.{{spaceId}}",
          "host": ["{{baseUrl}}"],
          "path": ["rest", "v1", "plants"],
          "query": [
            {
              "key": "space_id",
              "value": "eq.{{spaceId}}"
            }
          ]
        }
      }
    },
    {
      "name": "Plants: Update Stage",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Prefer",
            "value": "return=representation"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"current_stage\": \"vegetative\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/rest/v1/plants?id=eq.{{plantId}}",
          "host": ["{{baseUrl}}"],
          "path": ["rest", "v1", "plants"],
          "query": [
            {
              "key": "id",
              "value": "eq.{{plantId}}"
            }
          ]
        }
      }
    },
    {
      "name": "Data Logs: Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Prefer",
            "value": "return=representation"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"plant_id\": \"{{plantId}}\",\n  \"user_id\": \"{{userId}}\",\n  \"metric_type\": \"ph\",\n  \"value\": 6.5,\n  \"unit\": \"pH\",\n  \"notes\": \"Morning reading\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/rest/v1/data_logs",
          "host": ["{{baseUrl}}"],
          "path": ["rest", "v1", "data_logs"]
        }
      }
    },
    {
      "name": "Data Logs: Get by Plant",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/rest/v1/data_logs?plant_id=eq.{{plantId}}",
          "host": ["{{baseUrl}}"],
          "path": ["rest", "v1", "data_logs"],
          "query": [
            {
              "key": "plant_id",
              "value": "eq.{{plantId}}"
            }
          ]
        }
      }
    },
    {
      "name": "Data Logs: PATCH (append-only proof)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Prefer",
            "value": "return=representation"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"value\": 99.9\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/rest/v1/data_logs?id=eq.9cb521d1-96af-4905-a6c8-2cf0111b4a4f",
          "host": ["{{baseUrl}}"],
          "path": ["rest", "v1", "data_logs"],
          "query": [
            {
              "key": "id",
              "value": "eq.9cb521d1-96af-4905-a6c8-2cf0111b4a4f"
            }
          ]
        }
      }
    },
    {
      "name": "Tasks: Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Prefer",
            "value": "return=representation"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"space_id\": \"{{spaceId}}\",\n  \"user_id\": \"{{userId}}\",\n  \"plant_id\": \"{{plantId}}\",\n  \"title\": \"Water the pepper\",\n  \"due_date\": \"2026-06-15\",\n  \"status\": \"pending\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/rest/v1/tasks",
          "host": ["{{baseUrl}}"],
          "path": ["rest", "v1", "tasks"]
        }
      }
    },
    {
      "name": "Tasks: Get All",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/rest/v1/tasks?user_id=eq.{{userId}}",
          "host": ["{{baseUrl}}"],
          "path": ["rest", "v1", "tasks"],
          "query": [
            {
              "key": "user_id",
              "value": "eq.{{userId}}"
            }
          ]
        }
      }
    },
    {
      "name": "Tasks: Complete (trigger verification)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Prefer",
            "value": "return=representation"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"complete\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/rest/v1/tasks?id=eq.0d09be0b-59e4-450e-8054-abf864ef6e85",
          "host": ["{{baseUrl}}"],
          "path": ["rest", "v1", "tasks"],
          "query": [
            {
              "key": "id",
              "value": "eq.0d09be0b-59e4-450e-8054-abf864ef6e85"
